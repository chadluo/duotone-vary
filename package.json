{
  "publisher": "chadluo",
  "name": "duotone-vary",
  "displayName": "Duotone Vary",
  "description": "Duotone but you select the tone",
  "repository": {
    "type": "git",
    "url": "https://github.com/chadluo/duotone-vary"
  },
  "version": "1.0.0",
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Other"
  ],
  "icon": "images/DuotoneVary.png",
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "duotoneVary.regenerate",
        "title": "Duotone Vary: Regenerate Colors"
      }
    ],
    "themes": [
      {
        "label": "Duotone Vary Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/duotone-vary-dark.json"
      },
      {
        "label": "Duotone Vary Light",
        "uiTheme": "vs",
        "path": "./themes/duotone-vary-light.json"
      }
    ],
    "configuration": {
      "title": "Duotone Vary",
      "properties": {
        "duotoneVary.settingsTarget": {
          "order": 0,
          "type": "string",
          "enum": [
            "user",
            "workspace"
          ],
          "enumDescriptions": [
            "Write color customizations to user settings",
            "Write color customizations to workspace settings"
          ],
          "default": "user",
          "description": "Where to write the generated color customizations."
        },
        "duotoneVary.darkUnoColor": {
          "order": 1,
          "type": "string",
          "default": "",
          "markdownDescription": "Dark theme primary (Uno) color. Accepts CSS color values."
        },
        "duotoneVary.darkDuoColor": {
          "order": 2,
          "type": "string",
          "default": "",
          "markdownDescription": "Dark theme secondary/accent (Duo) color. Accepts CSS color values."
        },
        "duotoneVary.lightUnoColor": {
          "order": 3,
          "type": "string",
          "default": "",
          "markdownDescription": "Light theme primary (Uno) color. Accepts CSS color values."
        },
        "duotoneVary.lightDuoColor": {
          "order": 4,
          "type": "string",
          "default": "",
          "markdownDescription": "Light theme secondary/accent (Duo) color. Accepts CSS color values."
        }
      }
    }
  },
  "scripts": {
    "check-types": "tsc --noEmit",
    "compile": "pnpm run check-types && pnpm run lint && node esbuild.js",
    "compile-tests": "tsc -p . --outDir out",
    "lint": "eslint src",
    "package": "pnpm run check-types && pnpm run lint && node esbuild.js --production",
    "pretest": "pnpm run compile-tests && pnpm run compile && pnpm run lint",
    "test": "vscode-test",
    "vsce:package": "vsce package --no-dependencies --no-rewrite-relative-links",
    "vsce:publish": "vsce publish --no-dependencies",
    "watch": "npm-run-all -p watch:*",
    "watch-tests": "tsc -p . -w --outDir out",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.109.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.27.2",
    "eslint": "^9.39.2",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0"
  },
  "dependencies": {
    "colorjs.io": "^0.6.1"
  }
}